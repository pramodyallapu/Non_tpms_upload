{
  "project": "murphy & braddock",
  "version": "1.4",

  "detection": {
    "required_headers": [
      "date",
      "firstname",
      "lastname",
      "code",
      "charge",
      "balance",
      "ins_name1"
    ],
    "optional_headers": [
        "id_no",
        "lastbatch",
        "ins_dt_wof",
        "ins_status",
        "insuredid1"
    ]
  },

  "column_mappings": {
    "date": "dos",
    "code": "cpt",
    "charge": "unit_rate",
    "balance": "balance",
    "ins_name1": "payor_name",
    "casedrname": "provider_name"
  },

  "derived_fields": {
    "client_name": {
      "type": "concat",
      "columns": [
        "firstname",
        "lastname"
      ],
      "separator": " "
    },
    "units":{
      "type": "static",
      "value": "1"
    },
    "claim_id": {
    "type": "concat",
    "columns": [
      "name1",
      {
        "column": "date",
        "transform": "excel_serial"
      }
    ],
    "separator": ""
  }
  }
}
