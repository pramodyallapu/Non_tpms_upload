{
  "project": "Collaborative Psychology Group",
  "version": "1.1",
  "detection": {
    "required_headers": [
      "Claim ID",
      "Date Of Service",
      "Patient Name",
      "Charges",
      "Balance",
      "Payer Name",
      "Provider Name ",
      "Procedure Code"
    ],
    "optional_headers": [
      "Billed Units",
      "Office",
      "Client City",
      "Adjustments",
      "Primary Billed Date",
      "Secondary Payer",
      "Tertiary  Payer"
    ],
    "filters": {
      "deduplicate": true,
      "column_filter": [
      {
        "name": "Exclude_Values",
        "column": "Payer Balance",
        "type": "not_equals",
        "value": ""
      }
    ]
    }
  },
  "column_mappings": {
      "Claim ID":"claim_id",
      "Date Of Service":"dos",
      "Patient Name":"client_name",
      "Charges":"unit_rate",
      "Balance":"balance",
      "Provider Name":"provider_name",
      "Payer Name":"payor_name"
  },
  "derived_fields": {
    "units": {
      "type": "static",
      "value": 1
    },
    "cpt": {
    "type": "regex_extract",
    "column": "Procedure Code",
    "pattern": "^\\s*(\\d{5})"
    }
  }
}
