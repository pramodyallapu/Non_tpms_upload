            "value": 0
        },
        "patient_res": {
            "type": "static",
            "value": 0
        },
        "units": {
            "type": "static",
            "value": 1
        },
        "provider_name": {
            "type": "static",
            "value": ""
        },
        "payor_name": {
            "type": "static",
            "value": ""
        },
        "cpt": {
            "type": "static",
            "value": ""
        }
    }
