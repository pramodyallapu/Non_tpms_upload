{
    "project": "Insurance Aging Detail (Grouped)",
    "version": "1.3",
    "detection": {
        "type": "stateful",
        "required_headers": [
            "Patient Name <No.>",
            "Policy Number - Birth",
            "Enc.",
            "Total"
        ],
        "optional_headers": [
            "0-30",
            "31-60",
            "61-90",
            "91-120",
            "121-150",
            "151+"
        ],
        "filters": {
            "deduplicate": true,
            "column_filter": [
                {
                "name": "Exclude Zero Balance",
                "column": "balance",
                "type": "not_equals",
                "value": 0
                }
            ]
        }
    },
    "column_mappings": {
        "0": "dos",
        "3": "claim_id",
        "4": "unit_rate",
        "11": "balance"
    },
    "derived_fields": {
        "provider_name": {
            "type": "static",
            "value": "na"
        },
        "units": {
            "type": "static",
            "value": 1
        },
        "cpt": {
            "type": "static",
            "value": "na"
        },
        "primary": {
            "type": "static",
            "value": ""
        },
        "adjustment": {
            "type": "static",
            "value": ""
        },
        "patient_paid": {
            "type": "static",
            "value": ""
        },
        "patient_res": {
            "type": "static",
            "value": ""
        }
    }
}