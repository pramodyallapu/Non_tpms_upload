{
  "project_name": "Raso Report",
  "version": "1.2",
  "detection": {
    "type": "report",
    "required_markers": ["Carrier:", "Patient ID:", "Claim #:"],
    "extraction_rules": {
        "carrier": {
        "keyword": "Carrier:",
        "offset": 0,
        "transform": "split_after_paren"
        },
        "patient_name": {
        "keyword": "Patient ID:",
        "offset": 2
        },
        "claim_number": {
        "keyword": "Claim #:",
        "offset": 1
        }
    },
    "service_row_rules": {
        "date_column_index": 1,
        "columns": {
        "amount": 28,
        "insurance_due": 68
        }
    }
  },
  "column_mappings": {},
  "derived_fields": {
    "units": { "type": "static", "value": 1 },
    "provider_name": { "type": "static", "value": "na" }
  }
}
