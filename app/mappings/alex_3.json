{
  "project": "Alex_1.1",
  "version": "1.4",

  "detection": {
    "required_headers": [
      "Third Party Payer",
      "Provider",
      "First Name",
      "Last Name",
      "Date",
      "Billed Amount",
      "Insurance Balance"
    ],
    "optional_headers": [
      "Patient ID",
      "Item"
    ],
    "filters": {
    "column_filter": [
      {
        "name": "positive_balance",
        "column": "balance",
        "type": "not_equals",
        "value": 0
      }
    ]
    }
  },
  "column_mappings": {
    "Date": "dos",
    "Provider": "provider_name",
    "Third Party Payer": "payor_name",
    "Billed Amount": "unit_rate",
    "Insurance Balance": "balance"
  },
  "derived_fields": {
    "client_name": {
      "type": "concat",
      "columns": ["First Name", "Last Name"],
      "separator": " "
    },
    "payer_name": {
      "type": "conditional_replace",
      "column": "Third Party Payer",
      "condition": "equals",
      "value": "No Payer",
      "replace_with": "Insurance"
    },
    "cpt": {
      "type": "regex_extract",
      "column": "Item",
      "pattern": "\\[(.*?)\\]"
    },
    "units": {
      "type": "static",
      "value": 1
    },
    "claim_id": {
        "type": "concat",
        "columns": [
            ["First Name", "Last Name"],         
            {"column": "Date", "transform": "excel_serial"} 
        ],
        "separator": "",                
        "internal_separator": " "
    }
  }
}